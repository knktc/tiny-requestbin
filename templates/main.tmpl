<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tiny RequestBin</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="shortcut icon" href="/favicon.ico">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        // 语言翻译字典
        const translations = {
            'en': {
                'title': 'Tiny RequestBin',
                'subtitle_prefix': 'Send requests to',
                'auto_refresh': 'Auto Refresh',
                'auto_refresh_active': 'Live',
                'auto_refresh_inactive': 'Auto Off',
                'refresh_once': 'Refresh',
                'seconds': 'seconds',
                'refresh': 'Refresh',
                'clear_requests': 'Clear',
                'search_path': 'Search path',
                'search_path_placeholder': 'Filter by path, e.g. /api',
                'confirm': 'Confirm',
                'clear_confirm': 'Clear all captured requests?',
                'captured_requests': 'Captured Requests',
                'no_requests': 'No requests captured yet.',
                'no_filtered_requests': 'No requests match the current path filter.',
                'welcome_title': 'Welcome!',
                'welcome_message': 'Please select a request from the list on the left to view details.',
                'request_details': 'Request Details',
                'time': 'Time',
                'method': 'Method',
                'path': 'Path',
                'protocol': 'Protocol',
                'source_ip': 'Source IP',
                'query_parameters': 'Query Parameters',
                'no_query_parameters': 'No query parameters.',
                'headers': 'Headers',
                'body': 'Body',
                'no_body': 'This request has no body.',
                'copy': 'Copy',
                'copied': 'Copied!',
                'copy_failed': 'Failed'
            },
            'zh-CN': {
                'title': 'Tiny RequestBin',
                'subtitle_prefix': '发送请求到',
                'auto_refresh': '自动刷新',
                'auto_refresh_active': '自动刷新中',
                'auto_refresh_inactive': '自动刷新关闭',
                'refresh_once': '刷新',
                'seconds': '秒',
                'refresh': '刷新',
                'clear_requests': '清空',
                'search_path': '搜索路径',
                'search_path_placeholder': '按路径过滤，例如 /api',
                'confirm': '确定',
                'clear_confirm': '确定清空所有已捕获的请求？',
                'captured_requests': '已捕获的请求',
                'no_requests': '尚未捕获任何请求。',
                'no_filtered_requests': '当前路径筛选下没有匹配的请求。',
                'welcome_title': '欢迎！',
                'welcome_message': '请从左侧列表中选择一个请求以查看其详细信息。',
                'request_details': '请求详情',
                'time': '时间',
                'method': '方法',
                'path': '路径',
                'protocol': '协议',
                'source_ip': '源 IP',
                'query_parameters': '查询参数',
                'no_query_parameters': '没有查询参数。',
                'headers': '标头 (Headers)',
                'body': '正文 (Body)',
                'no_body': '该请求没有正文。',
                'copy': '复制',
                'copied': '已复制！',
                'copy_failed': '失败'
            }
        };

        // 设置当前语言
        let currentLang = 'en';
        
        // 语言检测和初始化函数
        function initLanguage() {
            // 检测浏览器语言
            const browserLang = navigator.language || navigator.userLanguage;
            
            // 如果是中文，设置为中文
            if (browserLang.startsWith('zh')) {
                currentLang = 'zh-CN';
            } else {
                currentLang = 'en';
            }
            
            // 设置HTML的lang属性
            document.documentElement.lang = currentLang;
            
            // 应用翻译
            applyTranslations();
        }
        
        // 应用翻译到页面
        function applyTranslations() {
            const elements = document.querySelectorAll('[data-i18n]');
            elements.forEach(el => {
                const key = el.getAttribute('data-i18n');
                if (translations[currentLang][key]) {
                    el.innerHTML = translations[currentLang][key];
                }
            });

            const placeholderElements = document.querySelectorAll('[data-i18n-placeholder]');
            placeholderElements.forEach(el => {
                const key = el.getAttribute('data-i18n-placeholder');
                if (translations[currentLang][key]) {
                    el.setAttribute('placeholder', translations[currentLang][key]);
                }
            });
            
            // 特殊处理一些动态元素
            document.title = translations[currentLang]['title'];
            renderSubtitle();
        }

        function renderSubtitle() {
            const subtitle = document.getElementById('subtitle');
            if (!subtitle) return;

            const origin = window.location.origin || `${window.location.protocol}//${window.location.host}`;
            const exampleUrl = `${origin}/your-path`;
            const prefix = translations[currentLang]['subtitle_prefix'] || '';

            const subtitleUrl = document.getElementById('subtitle-url');
            if (subtitleUrl) {
                subtitleUrl.textContent = exampleUrl;
            }

            const subtitlePrefix = document.getElementById('subtitle-prefix');
            if (subtitlePrefix) {
                subtitlePrefix.textContent = `${prefix} `;
            }
        }

        async function copyText(text) {
            if (navigator.clipboard && window.isSecureContext) {
                await navigator.clipboard.writeText(text);
                return;
            }

            const textArea = document.createElement('textarea');
            textArea.value = text;
            textArea.style.position = 'fixed';
            textArea.style.opacity = '0';
            document.body.appendChild(textArea);
            textArea.focus();
            textArea.select();
            document.execCommand('copy');
            document.body.removeChild(textArea);
        }
        
        // 页面加载完成后初始化语言
        document.addEventListener('DOMContentLoaded', () => {
            // Note: initLanguage() will be called in the main DOMContentLoaded handler
            // to ensure proper coordination with other initialization code
        });
    </script>
</head>
<body class="bg-gray-100 text-gray-800 font-sans h-screen flex flex-col">
    <header class="p-4 border-b bg-white shadow-sm flex justify-between items-center">
        <div class="w-1/3"></div>
        <div class="w-1/3 text-center">
            <h1 class="text-2xl font-bold text-gray-900" data-i18n="title">Tiny RequestBin</h1>
            <div id="subtitle" class="mt-1 flex items-center justify-center gap-2 text-sm text-gray-600">
                <p class="min-w-0">
                    <span id="subtitle-prefix">Send requests to </span><span id="subtitle-url" class="font-mono">http://127.0.0.1:8282/your-path</span>
                </p>
                <button id="copy-subtitle-btn" class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-md text-gray-500 transition-colors hover:text-gray-800 focus:outline-none focus:ring-2 focus:ring-indigo-200" title="Copy example URL" aria-label="Copy example URL">
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                    </svg>
                </button>
            </div>
        </div>
        <div class="w-1/3"></div>
    </header>

    <div class="flex flex-1 overflow-hidden">
        <!-- Left Column: Request List -->
        <aside class="w-1/3 bg-white border-r flex flex-col">
            <div class="p-4 border-b flex items-center justify-between gap-3">
                <h2 class="text-lg font-semibold" data-i18n="captured_requests">已捕获的请求</h2>
                <div class="flex items-center gap-2">
                    <div id="refreshControlGroup" class="inline-flex items-center rounded-full border border-slate-200 bg-slate-50 text-xs font-semibold text-slate-700 overflow-hidden">
                        <button id="autoRefreshToggleButton" class="inline-flex items-center gap-2 px-2.5 py-1.5 transition-colors hover:bg-slate-100">
                            <span id="autoRefreshStatusDot" class="h-2 w-2 rounded-full bg-slate-400"></span>
                            <span id="autoRefreshButtonLabel" data-i18n="auto_refresh_inactive">自动刷新</span>
                        </button>
                        <div class="h-4 w-px bg-slate-200"></div>
                        <label for="refreshIntervalInput" class="sr-only" data-i18n="seconds">秒</label>
                        <div class="inline-flex items-center gap-1 px-2 py-1.5 text-slate-600">
                            <input type="number" id="refreshIntervalInput" class="w-8 border-0 bg-transparent p-0 text-center text-xs font-semibold text-inherit focus:outline-none focus:ring-0" min="1" value="5">
                            <span data-i18n="seconds">秒</span>
                        </div>
                    </div>
                    <button id="listRefreshButton" class="inline-flex h-8 w-8 items-center justify-center rounded-md text-blue-600 transition-colors hover:bg-blue-50 hover:text-blue-700" title="Refresh" aria-label="Refresh">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                        </svg>
                    </button>
                    <button id="clearRequestsButton" class="px-3 py-1.5 text-xs font-semibold text-red-700 bg-red-50 border border-red-200 rounded-md hover:bg-red-100 hover:border-red-300 transition-colors flex items-center gap-1.5">
                        <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                            <path d="M8.5 2a1 1 0 00-1 1v1H4.75a.75.75 0 000 1.5h10.5a.75.75 0 000-1.5H12.5V3a1 1 0 00-1-1h-3z" />
                            <path d="M6 7.25a.75.75 0 01.75-.75h6.5a.75.75 0 01.75.75v7.25a2 2 0 01-2 2h-4a2 2 0 01-2-2V7.25z" />
                        </svg>
                        <span data-i18n="clear_requests">清理</span>
                    </button>
                </div>
            </div>
            <div class="p-4 border-b bg-gray-50">
                <label for="pathSearchInput" class="mb-2 block text-sm font-medium text-gray-700" data-i18n="search_path">搜索路径</label>
                <input
                    id="pathSearchInput"
                    type="search"
                    value="{{.PathFilter}}"
                    data-i18n-placeholder="search_path_placeholder"
                    placeholder="按路径过滤，例如 /api"
                    class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-200"
                >
            </div>
            <div class="overflow-y-auto flex-1">
                {{if .AllRequests}}
                <ul class="divide-y" id="requestList">
                    {{range .AllRequests}}
                    <a href="#" data-request-id="{{.ID}}" class="request-link block p-4 hover:bg-gray-50 {{if isCurrent .ID $.SelectedRequest}}bg-indigo-50 border-l-4 border-indigo-500{{end}}">
                        <div class="flex justify-between items-center mb-1">
                            <div class="font-bold truncate {{if isCurrent .ID $.SelectedRequest}}text-indigo-700{{else}}text-gray-800{{end}}">
                                <span class="px-2 mr-2 text-xs leading-5 font-semibold rounded-full 
                                    {{if eq .Method "GET"}} bg-green-100 text-green-800
                                    {{else if eq .Method "POST"}} bg-blue-100 text-blue-800
                                    {{else if eq .Method "PUT"}} bg-yellow-100 text-yellow-800
                                    {{else if eq .Method "DELETE"}} bg-red-100 text-red-800
                                    {{else}} bg-gray-100 text-gray-800 {{end}}">
                                    {{.Method}}
                                </span>
                                <span class="font-mono">{{if .RequestURI}}{{.RequestURI}}{{else}}{{.Path}}{{end}}</span>
                            </div>
                        </div>
                        <div class="text-xs text-gray-500">{{.Timestamp | formatTime}}</div>
                    </a>
                {{end}}
                </ul>
                {{else}}
                <div class="p-6 text-center text-gray-500">
                    <p data-i18n="{{if .PathFilter}}no_filtered_requests{{else}}no_requests{{end}}">{{if .PathFilter}}当前路径筛选下没有匹配的请求。{{else}}尚未捕获任何请求。{{end}}</p>
                </div>
                {{end}}
            </div>
            <!-- Pagination Controls -->
            <div id="paginationControls" class="p-4 border-t bg-gray-50">
                <div class="flex items-center justify-between text-sm">
                    <div class="text-gray-600">
                        <span id="paginationInfo">第 1 页，共 1 页 (总计 {{len .AllRequests}} 个请求)</span>
                    </div>
                    <div class="flex space-x-2">
                        <button id="prevPageBtn" class="px-3 py-1 text-sm bg-gray-200 text-gray-600 rounded hover:bg-gray-300 disabled:opacity-50 disabled:cursor-not-allowed" disabled>
                            上一页
                        </button>
                        <button id="nextPageBtn" class="px-3 py-1 text-sm bg-gray-200 text-gray-600 rounded hover:bg-gray-300 disabled:opacity-50 disabled:cursor-not-allowed">
                            下一页
                        </button>
                    </div>
                </div>
            </div>
        </aside>

        <!-- Right Column: Request Details -->
        <main class="w-2/3 overflow-y-auto p-4 md:p-8">
            {{if .SelectedRequest}}
            <div class="bg-white rounded-lg shadow-md mb-6">
                <div class="p-5 md:p-6">
                    <div class="flex flex-wrap items-center gap-3">
                        <h2 class="text-xl font-semibold text-gray-900"><span data-i18n="request_details">请求详情</span> #{{.SelectedRequest.ID}}</h2>
                        <span class="inline-flex items-center rounded-full px-2.5 py-1 text-xs font-semibold
                            {{if eq .SelectedRequest.Method "GET"}} bg-green-100 text-green-800
                            {{else if eq .SelectedRequest.Method "POST"}} bg-blue-100 text-blue-800
                            {{else if eq .SelectedRequest.Method "PUT"}} bg-yellow-100 text-yellow-800
                            {{else if eq .SelectedRequest.Method "DELETE"}} bg-red-100 text-red-800
                            {{else}} bg-gray-100 text-gray-800 {{end}}">
                            {{.SelectedRequest.Method}}
                        </span>
                        <span class="inline-flex items-center rounded-full bg-slate-100 px-2.5 py-1 text-xs font-medium text-slate-700">{{.SelectedRequest.Proto}}</span>
                        <span class="inline-flex items-center rounded-full bg-slate-100 px-2.5 py-1 text-xs font-medium text-slate-700 font-mono">{{.SelectedRequest.RemoteAddr}}</span>
                        <span class="text-sm text-gray-500">{{.SelectedRequest.Timestamp | formatTime}}</span>
                    </div>
                    <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50 px-4 py-3">
                        <div class="text-xs font-semibold uppercase tracking-wide text-slate-500" data-i18n="path">路径</div>
                        <div class="mt-1 break-all font-mono text-sm text-slate-900">{{if .SelectedRequest.RequestURI}}{{.SelectedRequest.RequestURI}}{{else}}{{.SelectedRequest.Path}}{{end}}</div>
                    </div>
                </div>
            </div>

            <div class="grid gap-6 xl:grid-cols-5">
                <div class="space-y-6 xl:col-span-2">
                    <div class="bg-white rounded-lg shadow-md">
                        <div id="headers-toggle" class="px-5 py-4 border-b flex justify-between items-center cursor-pointer hover:bg-gray-50">
                            <h2 class="text-lg font-semibold" data-i18n="headers">标头 (Headers)</h2>
                            <svg id="headers-chevron" class="w-5 h-5 transform transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                        </div>
                        <div id="headers-content" class="px-5 py-4 overflow-auto transition-all duration-300 max-h-72">
                            <dl class="space-y-3">
                                {{range $key, $values := .SelectedRequest.Headers}}
                                    <div class="rounded-lg bg-slate-50 px-3 py-2">
                                        <dt class="text-xs font-semibold uppercase tracking-wide text-slate-500 break-all">{{$key}}</dt>
                                        <dd class="mt-1 text-sm text-slate-900 font-mono break-all">{{range $values}}{{.}}{{end}}</dd>
                                    </div>
                                {{end}}
                            </dl>
                        </div>
                    </div>

                    <div class="bg-white rounded-lg shadow-md">
                        <div id="query-toggle" class="px-5 py-4 border-b flex justify-between items-center cursor-pointer hover:bg-gray-50">
                            <h2 class="text-lg font-semibold" data-i18n="query_parameters">查询参数</h2>
                            <svg id="query-chevron" class="w-5 h-5 transform transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                        </div>
                        <div id="query-content" class="px-5 py-4 overflow-auto transition-all duration-300 max-h-72" data-has-content="{{if .SelectedRequest.QueryParams}}true{{else}}false{{end}}">
                            {{if .SelectedRequest.QueryParams}}
                            <dl class="space-y-3">
                                {{range $key, $values := .SelectedRequest.QueryParams}}
                                    <div class="rounded-lg bg-slate-50 px-3 py-2">
                                        <dt class="text-xs font-semibold uppercase tracking-wide text-slate-500 break-all">{{$key}}</dt>
                                        <dd class="mt-1 text-sm text-slate-900 font-mono break-all">{{range $index, $value := $values}}{{if $index}}, {{end}}{{$value}}{{end}}</dd>
                                    </div>
                                {{end}}
                            </dl>
                            {{else}}
                            <p class="text-sm text-gray-500" data-i18n="no_query_parameters">没有查询参数。</p>
                            {{end}}
                        </div>
                    </div>
                </div>

                <div class="xl:col-span-3">
                    <div class="bg-white rounded-lg shadow-md">
                        <div id="body-toggle" class="px-5 py-4 border-b flex justify-between items-center cursor-pointer hover:bg-gray-50">
                            <h2 class="text-lg font-semibold" data-i18n="body">正文 (Body)</h2>
                            <svg id="body-chevron" class="w-5 h-5 transform transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                        </div>
                        <div id="body-content" class="p-5 transition-all duration-300 relative">
                            {{if .SelectedRequest.Body}}
                                <div class="relative">
                                    <pre id="body-text" class="max-h-[60vh] overflow-auto rounded-xl bg-gray-900 p-4 text-sm text-white shadow-inner"><code>{{prettyPrintJson .SelectedRequest.Body}}</code></pre>
                                    <button id="copy-body-btn" class="absolute top-2 right-2 bg-blue-600 hover:bg-blue-700 text-white p-2 rounded-md text-xs transition-colors duration-200 flex items-center gap-1" title="复制正文内容">
                                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                                        </svg>
                                        <span data-i18n="copy">复制</span>
                                    </button>
                                </div>
                            {{else}}
                                <div class="rounded-xl border border-dashed border-slate-200 bg-slate-50 px-4 py-6 text-sm text-gray-500" data-i18n="no_body">该请求没有正文。</div>
                            {{end}}
                        </div>
                    </div>
                </div>
            </div>
            {{else}}
            <div class="flex items-center justify-center h-full">
                <div class="text-center text-gray-500">
                    <h2 class="text-2xl font-semibold" data-i18n="welcome_title">欢迎！</h2>
                    <p class="mt-2" data-i18n="welcome_message">请从左侧列表中选择一个请求以查看其详细信息。</p>
                </div>
            </div>
            {{end}}
        </main>
    </div>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Initialize language first
            initLanguage();
            
            // --- Pagination variables ---
            let currentPage = 1;
            let totalPages = 1;
            let isUpdating = false;
            
            // --- Auto-refresh logic ---
            const autoRefreshToggleButton = document.getElementById('autoRefreshToggleButton');
            const autoRefreshButtonLabel = document.getElementById('autoRefreshButtonLabel');
            const autoRefreshStatusDot = document.getElementById('autoRefreshStatusDot');
            const refreshControlGroup = document.getElementById('refreshControlGroup');
            const intervalInput = document.getElementById('refreshIntervalInput');
            const clearRequestsButton = document.getElementById('clearRequestsButton');
            const listRefreshButton = document.getElementById('listRefreshButton');
            const pathSearchInput = document.getElementById('pathSearchInput');
            const requestList = document.querySelector('aside .overflow-y-auto');
            let refreshInterval;
            let searchDebounceTimer;
            let currentPathFilter = new URLSearchParams(window.location.search).get('path') || '';
            let isAutoRefreshEnabled = true;

            // --- Pagination controls ---
            const prevPageBtn = document.getElementById('prevPageBtn');
            const nextPageBtn = document.getElementById('nextPageBtn');
            const paginationInfo = document.getElementById('paginationInfo');
            const paginationControls = document.getElementById('paginationControls');

            if (pathSearchInput) {
                pathSearchInput.value = currentPathFilter;
            }

            function startRefresh() {
                if (refreshInterval) clearInterval(refreshInterval);
                let interval = parseInt(intervalInput.value, 10);
                if (isNaN(interval) || interval < 1) {
                    interval = 5; // 如果输入无效，则重置为默认值
                    intervalInput.value = '5';
                }
                refreshInterval = setInterval(() => updateRequestList(), interval * 1000);
            }

            function stopRefresh() {
                clearInterval(refreshInterval);
                refreshInterval = null;
            }

            function updateRefreshControls() {
                if (!autoRefreshToggleButton || !autoRefreshButtonLabel || !autoRefreshStatusDot || !refreshControlGroup || !listRefreshButton) {
                    return;
                }

                if (isAutoRefreshEnabled) {
                    refreshControlGroup.className = 'inline-flex items-center rounded-full border border-emerald-200 bg-emerald-50 text-xs font-semibold text-emerald-700 overflow-hidden';
                    autoRefreshToggleButton.className = 'inline-flex items-center gap-2 px-2.5 py-1.5 transition-colors hover:bg-emerald-100';
                    autoRefreshButtonLabel.textContent = translations[currentLang]['auto_refresh_active'];
                    autoRefreshStatusDot.className = 'h-2 w-2 rounded-full bg-emerald-500';
                    listRefreshButton.classList.add('hidden');
                } else {
                    refreshControlGroup.className = 'inline-flex items-center rounded-full border border-slate-200 bg-slate-50 text-xs font-semibold text-slate-700 overflow-hidden';
                    autoRefreshToggleButton.className = 'inline-flex items-center gap-2 px-2.5 py-1.5 transition-colors hover:bg-slate-100';
                    autoRefreshButtonLabel.textContent = translations[currentLang]['auto_refresh_inactive'];
                    autoRefreshStatusDot.className = 'h-2 w-2 rounded-full bg-slate-400';
                    listRefreshButton.classList.remove('hidden');
                }
            }

            function syncUrlParams({ page = currentPage, path = currentPathFilter, viewId } = {}) {
                const url = new URL(window.location);

                if (path) {
                    url.searchParams.set('path', path);
                } else {
                    url.searchParams.delete('path');
                }

                if (page > 1) {
                    url.searchParams.set('page', page);
                } else {
                    url.searchParams.delete('page');
                }

                if (viewId) {
                    url.searchParams.set('view_id', viewId);
                } else if (viewId === null) {
                    url.searchParams.delete('view_id');
                }

                window.history.replaceState({}, '', url);
            }


            // Function to update pagination info
            function updatePaginationInfo(data) {
                const { page, total_pages, total } = data;
                paginationInfo.textContent = `第 ${page} 页，共 ${total_pages} 页 (总计 ${total} 个请求)`;
                
                prevPageBtn.disabled = !data.has_prev;
                nextPageBtn.disabled = !data.has_next;
                
                currentPage = page;
                totalPages = total_pages;
                
                // Show/hide pagination controls based on whether there are multiple pages
                if (total_pages > 1) {
                    paginationControls.classList.remove('hidden');
                } else {
                    paginationControls.classList.add('hidden');
                }
            }

            // Function to update only the request list via AJAX
            function updateRequestList(page = currentPage) {
                if (isUpdating) return;
                isUpdating = true;
                const params = new URLSearchParams({
                    page: String(page),
                    limit: '20'
                });

                if (currentPathFilter) {
                    params.set('path', currentPathFilter);
                }
                
                return fetch(`/api/requests?${params.toString()}`)
                    .then(response => response.json())
                    .then(data => {
                        const currentViewId = new URLSearchParams(window.location.search).get('view_id');
                        
                        updatePaginationInfo(data);
                        syncUrlParams({ page: data.page, path: currentPathFilter });
                        
                        if (data.requests && data.requests.length > 0) {
                            const ul = document.createElement('ul');
                            ul.className = 'divide-y';
                            ul.id = 'requestList';
                            
                            data.requests.forEach(request => {
                                const li = document.createElement('a');
                                li.href = '#';
                                li.setAttribute('data-request-id', request.ID);
                                li.className = `request-link block p-4 hover:bg-gray-50 ${currentViewId == request.ID ? 'bg-indigo-50 border-l-4 border-indigo-500' : ''}`;
                                
                                const methodColor = getMethodColor(request.Method);
                                const timestamp = formatTime(request.Timestamp);
                                
                                li.innerHTML = `
                                    <div class="flex justify-between items-center mb-1">
                                        <div class="font-bold truncate ${currentViewId == request.ID ? 'text-indigo-700' : 'text-gray-800'}">
                                            <span class="px-2 mr-2 text-xs leading-5 font-semibold rounded-full ${methodColor}">
                                                ${request.Method}
                                            </span>
                                            <span class="font-mono">${request.RequestURI || request.Path}</span>
                                        </div>
                                    </div>
                                    <div class="text-xs text-gray-500">${timestamp}</div>
                                `;
                                
                                // Add click event listener
                                li.addEventListener('click', handleRequestClick);
                                
                                ul.appendChild(li);
                            });
                            
                            requestList.innerHTML = '';
                            requestList.appendChild(ul);
                        } else {
                            const emptyMessageKey = currentPathFilter ? 'no_filtered_requests' : 'no_requests';
                            requestList.innerHTML = `
                                <div class="p-6 text-center text-gray-500">
                                    <p data-i18n="${emptyMessageKey}">${translations[currentLang][emptyMessageKey]}</p>
                                </div>
                            `;
                        }
                    })
                    .catch(error => {
                        console.error('Error updating request list:', error);
                    })
                    .finally(() => {
                        isUpdating = false;
                    });
            }

            // Helper function to get method color class
            function getMethodColor(method) {
                switch(method) {
                    case 'GET': return 'bg-green-100 text-green-800';
                    case 'POST': return 'bg-blue-100 text-blue-800';
                    case 'PUT': return 'bg-yellow-100 text-yellow-800';
                    case 'DELETE': return 'bg-red-100 text-red-800';
                    default: return 'bg-gray-100 text-gray-800';
                }
            }

            // Helper function to format time in the same format as server-side formatTime
            function formatTime(dateString) {
                const date = new Date(dateString);
                const year = date.getFullYear();
                const month = String(date.getMonth() + 1).padStart(2, '0');
                const day = String(date.getDate()).padStart(2, '0');
                const hours = String(date.getHours()).padStart(2, '0');
                const minutes = String(date.getMinutes()).padStart(2, '0');
                const seconds = String(date.getSeconds()).padStart(2, '0');
                return `${year}-${month}-${day} ${hours}:${minutes}:${seconds}`;
            }

            // Pagination button event listeners
            prevPageBtn.addEventListener('click', () => {
                if (currentPage > 1) {
                    updateRequestList(currentPage - 1);
                }
            });

            nextPageBtn.addEventListener('click', () => {
                if (currentPage < totalPages) {
                    updateRequestList(currentPage + 1);
                }
            });

            autoRefreshToggleButton.addEventListener('click', () => {
                localStorage.setItem('autoRefreshInterval', intervalInput.value);
                isAutoRefreshEnabled = !isAutoRefreshEnabled;
                if (isAutoRefreshEnabled) {
                    localStorage.setItem('autoRefreshEnabled', 'true');
                    startRefresh();
                } else {
                    localStorage.setItem('autoRefreshEnabled', 'false');
                    stopRefresh();
                }
                updateRefreshControls();
            });


            if (clearRequestsButton) {
                let isConfirmingClear = false;
                let clearConfirmTimer = null;
                const clearOriginalClasses = clearRequestsButton.className;
                const clearOriginalLabel = clearRequestsButton.innerHTML;

                const resetClearButton = () => {
                    isConfirmingClear = false;
                    clearRequestsButton.className = clearOriginalClasses;
                    clearRequestsButton.innerHTML = clearOriginalLabel;
                    if (clearConfirmTimer) {
                        clearTimeout(clearConfirmTimer);
                        clearConfirmTimer = null;
                    }
                };

                clearRequestsButton.addEventListener('click', async () => {
                    if (clearRequestsButton.disabled) return;

                    if (!isConfirmingClear) {
                        isConfirmingClear = true;
                        clearRequestsButton.className = 'px-3 py-1.5 text-xs font-semibold text-white bg-red-600 border border-red-600 rounded-md hover:bg-red-700 transition-colors flex items-center gap-1.5';
                        clearRequestsButton.innerHTML = `
                            <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                <path fill-rule="evenodd" d="M16.704 6.29a.75.75 0 010 1.06l-7.25 7.25a.75.75 0 01-1.06 0l-3.25-3.25a.75.75 0 111.06-1.06l2.72 2.72 6.72-6.72a.75.75 0 011.06 0z" clip-rule="evenodd" />
                            </svg>
                            <span data-i18n="confirm">${translations[currentLang]['confirm']}</span>
                        `;
                        clearConfirmTimer = setTimeout(resetClearButton, 2500);
                        return;
                    }

                    clearRequestsButton.disabled = true;
                    clearRequestsButton.classList.add('opacity-60', 'cursor-not-allowed');

                    try {
                        const response = await fetch('/api/requests/clear', { method: 'POST' });
                        if (!response.ok) {
                            throw new Error('clear_failed');
                        }
                        window.location.href = '/';
                    } catch (error) {
                        console.error('Error clearing requests:', error);
                        clearRequestsButton.disabled = false;
                        clearRequestsButton.classList.remove('opacity-60', 'cursor-not-allowed');
                        resetClearButton();
                    }
                });
            }

            if (pathSearchInput) {
                pathSearchInput.addEventListener('input', () => {
                    currentPathFilter = pathSearchInput.value.trim();
                    currentPage = 1;

                    if (searchDebounceTimer) {
                        clearTimeout(searchDebounceTimer);
                    }

                    syncUrlParams({ page: 1, path: currentPathFilter, viewId: null });
                    searchDebounceTimer = setTimeout(() => {
                        updateRequestList(1);
                    }, 300);
                });
            }

            if (listRefreshButton) {
                listRefreshButton.addEventListener('click', () => {
                    if (isUpdating) return;
                    const refreshIcon = listRefreshButton.querySelector('svg');
                    listRefreshButton.disabled = true;
                    listRefreshButton.classList.add('opacity-70', 'cursor-not-allowed');
                    if (refreshIcon) {
                        refreshIcon.classList.add('animate-spin');
                    }
                    Promise.resolve(updateRequestList())
                        .catch(() => {})
                        .finally(() => {
                            if (refreshIcon) {
                                refreshIcon.classList.remove('animate-spin');
                            }
                            listRefreshButton.disabled = false;
                            listRefreshButton.classList.remove('opacity-70', 'cursor-not-allowed');
                        });
                });
            }
            
            intervalInput.addEventListener('change', () => {
                let interval = parseInt(intervalInput.value, 10);
                if (isNaN(interval) || interval < 1) {
                    intervalInput.value = '5'; // 重置为默认值
                }
                localStorage.setItem('autoRefreshInterval', intervalInput.value);
                if (isAutoRefreshEnabled) {
                    startRefresh(); // 如果已启用，则使用新间隔重新启动
                }
            });

            // 页面加载时恢复设置
            const savedInterval = localStorage.getItem('autoRefreshInterval') || '5';
            intervalInput.value = savedInterval;
            isAutoRefreshEnabled = localStorage.getItem('autoRefreshEnabled') !== 'false';
            const initialPage = parseInt(new URLSearchParams(window.location.search).get('page') || '1', 10);
            if (!Number.isNaN(initialPage) && initialPage > 0) {
                currentPage = initialPage;
            }
            if (isAutoRefreshEnabled) {
                startRefresh();
            }
            updateRefreshControls();

            // Initialize pagination and request list
            updateRequestList();

            // Handle request link clicks
            function handleRequestClick(event) {
                event.preventDefault();
                const requestId = event.currentTarget.getAttribute('data-request-id');
                if (requestId) {
                    // Update URL without page reload
                    const newUrl = new URL(window.location);
                    newUrl.searchParams.set('view_id', requestId);
                    window.history.pushState({}, '', newUrl);
                    
                    // Update the display
                    loadRequestDetails(requestId);
                }
            }

            // Add click event listeners to existing request links
            document.querySelectorAll('.request-link').forEach(link => {
                link.addEventListener('click', handleRequestClick);
            });

            // Function to load request details via AJAX
            function loadRequestDetails(requestId) {
                const newUrl = new URL(window.location);
                newUrl.pathname = '/';
                newUrl.searchParams.set('view_id', requestId);
                if (currentPathFilter) {
                    newUrl.searchParams.set('path', currentPathFilter);
                } else {
                    newUrl.searchParams.delete('path');
                }
                if (currentPage > 1) {
                    newUrl.searchParams.set('page', currentPage);
                } else {
                    newUrl.searchParams.delete('page');
                }
                window.location.href = newUrl.toString();
            }

            // --- Collapsible sections logic ---
            const sections = ['headers', 'query', 'body'];

            sections.forEach(section => {
                const toggle = document.getElementById(section + '-toggle');
                const content = document.getElementById(section + '-content');
                const chevron = document.getElementById(section + '-chevron');
                const storageKey = section + 'Collapsed';

                const setCollapsedState = (isCollapsed, isInitial) => {
                    if(isCollapsed) {
                        content.classList.add('hidden');
                        chevron.classList.add('rotate-180');
                    } else {
                        content.classList.remove('hidden');
                        chevron.classList.remove('rotate-180');
                    }
                    if (!isInitial && section !== 'query') {
                         localStorage.setItem(storageKey, isCollapsed);
                    }
                };
                
                if (toggle) {
                     toggle.addEventListener('click', () => {
                        const isCollapsed = !content.classList.contains('hidden');
                        setCollapsedState(isCollapsed, false);
                    });
                }
               
                if (content) {
                    let initiallyCollapsed;
                    if (section === 'query') {
                        initiallyCollapsed = content.dataset.hasContent === 'false';
                    } else {
                        const savedCollapsed = localStorage.getItem(storageKey);
                        initiallyCollapsed = savedCollapsed === 'true';
                    }
                    setCollapsedState(initiallyCollapsed, true);
                }
            });

            // --- Copy button functionality ---
            const copySubtitleBtn = document.getElementById('copy-subtitle-btn');
            if (copySubtitleBtn) {
                copySubtitleBtn.addEventListener('click', async () => {
                    const subtitleUrl = document.getElementById('subtitle-url');
                    if (!subtitleUrl) return;

                    try {
                        await copyText(subtitleUrl.textContent || subtitleUrl.innerText || '');

                        const originalContent = copySubtitleBtn.innerHTML;
                        copySubtitleBtn.innerHTML = `
                            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                            </svg>
                        `;
                        copySubtitleBtn.classList.remove('text-gray-500', 'hover:text-gray-800');
                        copySubtitleBtn.classList.add('text-green-600');
                        copySubtitleBtn.title = translations[currentLang]['copied'];
                        copySubtitleBtn.setAttribute('aria-label', translations[currentLang]['copied']);

                        setTimeout(() => {
                            copySubtitleBtn.innerHTML = originalContent;
                            copySubtitleBtn.classList.remove('text-green-600');
                            copySubtitleBtn.classList.add('text-gray-500', 'hover:text-gray-800');
                            copySubtitleBtn.title = 'Copy example URL';
                            copySubtitleBtn.setAttribute('aria-label', 'Copy example URL');
                        }, 2000);
                    } catch (err) {
                        console.error('Failed to copy subtitle URL: ', err);

                        const originalContent = copySubtitleBtn.innerHTML;
                        copySubtitleBtn.innerHTML = `
                            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                            </svg>
                        `;
                        copySubtitleBtn.classList.remove('text-gray-500', 'hover:text-gray-800');
                        copySubtitleBtn.classList.add('text-red-600');
                        copySubtitleBtn.title = translations[currentLang]['copy_failed'];
                        copySubtitleBtn.setAttribute('aria-label', translations[currentLang]['copy_failed']);

                        setTimeout(() => {
                            copySubtitleBtn.innerHTML = originalContent;
                            copySubtitleBtn.classList.remove('text-red-600');
                            copySubtitleBtn.classList.add('text-gray-500', 'hover:text-gray-800');
                            copySubtitleBtn.title = 'Copy example URL';
                            copySubtitleBtn.setAttribute('aria-label', 'Copy example URL');
                        }, 2000);
                    }
                });
            }

            const copyBodyBtn = document.getElementById('copy-body-btn');
            if (copyBodyBtn) {
                copyBodyBtn.addEventListener('click', async () => {
                    const bodyText = document.getElementById('body-text');
                    if (bodyText) {
                        try {
                            // Get the text content without HTML tags
                            const textToCopy = bodyText.textContent || bodyText.innerText;
                            await copyText(textToCopy);
                            
                            // Visual feedback
                            const originalContent = copyBodyBtn.innerHTML;
                            copyBodyBtn.innerHTML = `
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                                </svg>
                                <span data-i18n="copied">${translations[currentLang]['copied']}</span>
                            `;
                            copyBodyBtn.classList.remove('bg-blue-600', 'hover:bg-blue-700');
                            copyBodyBtn.classList.add('bg-green-600', 'hover:bg-green-700');
                            
                            // Reset after 2 seconds
                            setTimeout(() => {
                                copyBodyBtn.innerHTML = originalContent;
                                copyBodyBtn.classList.remove('bg-green-600', 'hover:bg-green-700');
                                copyBodyBtn.classList.add('bg-blue-600', 'hover:bg-blue-700');
                            }, 2000);
                            
                        } catch (err) {
                            console.error('Failed to copy text: ', err);
                            // Show error feedback
                            const originalContent = copyBodyBtn.innerHTML;
                            copyBodyBtn.innerHTML = `
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                                </svg>
                                <span>${translations[currentLang]['copy_failed']}</span>
                            `;
                            copyBodyBtn.classList.remove('bg-blue-600', 'hover:bg-blue-700');
                            copyBodyBtn.classList.add('bg-red-600', 'hover:bg-red-700');
                            
                            setTimeout(() => {
                                copyBodyBtn.innerHTML = originalContent;
                                copyBodyBtn.classList.remove('bg-red-600', 'hover:bg-red-700');
                                copyBodyBtn.classList.add('bg-blue-600', 'hover:bg-blue-700');
                            }, 2000);
                        }
                    }
                });
            }
        });
    </script>
</body>
</html>
